APP_NAME=Barbershop Backend
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# Neon dashboard -> Connect -> Connection string.
# Paste the URL without the "psql" command and without a DATABASE_URL= prefix.
# Both direct and pooled Neon URLs work. channel_binding=require is removed automatically
# because asyncpg/SQLAlchemy does not accept it as a connection keyword.
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-your-db.us-east-1.aws.neon.tech/neondb?sslmode=require

JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=120

TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_BOT_USERNAME=Barber_shop_001_bot

DATABASE_CONNECT_TIMEOUT_SECONDS=8
DATABASE_COMMAND_TIMEOUT_SECONDS=15
DATABASE_STARTUP_MAX_ATTEMPTS=3
DATABASE_STARTUP_RETRY_SECONDS=5
